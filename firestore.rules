rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    // ============ USERS ============
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      // 可以更新自己的資料，但不能改 role/plan/subscriptionStatus/stripeCustomerId/subscriptionId/dailyLimit
      allow update: if isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'role', 'plan', 'dailyLimit', 'subscriptionStatus', 
            'stripeCustomerId', 'subscriptionId', 'messagesUsedToday'
          ]);
      
      allow create: if isOwner(userId);
      allow delete: if false;
    }
    
    // ============ CHARACTERS ============
    match /characters/{characterId} {
      // 公開角色 anyone can read
      allow read: if resource.data.visibility == 'public';
      
      // 自己的角色可以讀寫
      allow read, write: if isAuthenticated() && 
        (resource.data.ownerUid == request.auth.uid || request.resource.data.ownerUid == request.auth.uid);
      
      // 查詢時只能查自己的
      allow list: if isAuthenticated();
    }
    
    // ============ CONVERSATIONS ============
    match /conversations/{docId} {
      allow read, write: if isAuthenticated() && docId.startswith(request.auth.uid);
    }
    
    // ============ MESSAGES ============
    match /messages/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}